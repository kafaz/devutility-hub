# ── 依赖 & 构建产物 ──────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/

# ── 日志 ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── 环境变量（含敏感信息，绝不提交） ─────────────────────────
.env
.env.*
!.env.example

# ── 编辑器 / 系统 ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── 本地测试脚本 ──────────────────────────────────────────
*.local
__pycache__/
*.py[cod]

# ── 运行期数据 / 凭据预设 ──────────────────────────────────
server/data/*.json
!server/data/*.example.json
